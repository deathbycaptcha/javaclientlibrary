{
  "@context": {
    "dbc": "https://deathbycaptcha.com/schema#",
    "baseURL": "dbc:baseURL",
    "endpoint": "dbc:endpoint",
    "path": "dbc:path",
    "method": "dbc:method",
    "description": "dbc:description"
  },
  "baseURL": "https://api.dbcapi.me/api",
  "note": "Use HTTPS for security. HTTP available at http://api.dbcapi.me/api (legacy fallback only).",
  "endpoints": [
    {
      "path": "/",
      "method": "GET",
      "description": "Official docs describe balance lookup as GET to `/api` with either\n`username`+`password` or `authtoken`."
    },
    {
      "path": "/",
      "method": "POST",
      "description": ""
    },
    {
      "path": "/captcha",
      "method": "POST",
      "description": "Upload a captcha using multipart/form-data (file in `captchafile`) or\nby providing base64 content in the `captcha` field. Use `type` to\nspecify specialized APIs: 2=Coordinates, 3=Image Group, 4=Token, 5=reCAPTCHA v3\n(see below for a full list of types up to 25).  **All types share the\nsame response structure:** the server always returns a JSON object\nconforming to `CaptchaResponse` containing at minimum a `captcha` id\nand `status`.  Clients are expected to poll `/captcha/{id}` to check for\ncompletion; until solved the `text` field will be empty or null and\n`is_correct` is false.  A reply with HTTP 501 indicates missing\nparameters or an unsupported combination of type/fields; this should be\ntreated as a hard error rather than a solvable captcha."
    },
    {
      "path": "/captcha/{captchaId}",
      "method": "GET",
      "description": ""
    },
    {
      "path": "/captcha/{captchaId}/report",
      "method": "POST",
      "description": "Report a captcha as incorrectly solved. After reporting, the captcha's\n`is_correct` field will be set to false. Requires authentication via\nusername/password or authtoken."
    },
    {
      "path": "/status",
      "method": "GET",
      "description": "Query the API for operational metrics.  Returned fields mirror the\nofficial documentation at https://deathbycaptcha.com/api#api_details."
    }
  ]
}